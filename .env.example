# Configuração da Aplicação
APP_NAME="Terminal Operebem"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# Banco de Dados Principal
# Opções: mysql ou pgsql
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=terminal_operebem
DB_USERNAME=root
DB_PASSWORD=

# Banco de Dados de Cotações (PostgreSQL)
QUOTES_DB_HOST=localhost
QUOTES_DB_PORT=5432
QUOTES_DB_DATABASE=quotes_db
QUOTES_DB_USERNAME=postgres
QUOTES_DB_PASSWORD=

# Banco de Dados Aluno (PostgreSQL)
ALUNO_DB_HOST=localhost
ALUNO_DB_PORT=5432
ALUNO_DB_DATABASE=aluno_db
ALUNO_DB_USERNAME=postgres
ALUNO_DB_PASSWORD=

# JWT (JSON Web Token)
JWT_SECRET=sua_chave_secreta_aqui_mude_isso
JWT_EXPIRATION=86400

# Sessão
SESSION_LIFETIME_MINUTES=720

# reCAPTCHA (opcional para desenvolvimento local)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Email (opcional)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@terminal.operebem.com.br
MAIL_FROM_NAME="${APP_NAME}"

# Logs de Auditoria
# Retenção de logs em dias (padrão: 90 dias = 3 meses)
AUDIT_LOG_RETENTION_DAYS=90

# Integracao com Portal do Aluno (sync de pricing e materiais)
PORTAL_ALUNO_BASE_URL=https://aluno.operebem.com.br
TERMINAL_SYNC_SECRET=

# Bunny Storage (upload de materiais)
# Exemplo de region: br, ny, la, sg (vazio usa storage global)
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_ACCESS_KEY=
BUNNY_STORAGE_REGION=
# URL publica da CDN/Pull Zone (ex: https://cdn.operebem.com)
BUNNY_STORAGE_PUBLIC_BASE_URL=

# Media Origin dedicado (Hostinger)
MEDIA_ORIGIN_BASE_URL=
MEDIA_ORIGIN_UPLOAD_PATH=/api/upload.php
MEDIA_ORIGIN_UPLOAD_TOKEN=
MEDIA_ORIGIN_DOWNLOAD_BASE_URL=
MEDIA_ORIGIN_SIGNING_KEY=
MEDIA_ORIGIN_SIGNING_TTL=600
MEDIA_ORIGIN_TIMEOUT=30
